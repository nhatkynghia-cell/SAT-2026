# ============================================================================
#  BIẾN MÔI TRƯỜNG CẦN SET (sao chép file này thành .env.local rồi điền giá trị)
#  KHÔNG commit .env.local — đã được .gitignore che (.env*).
# ============================================================================

# --- Supabase (Auth + Database) ---
# Lấy ở Supabase Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# --- Supabase Service Role (SERVER-ONLY, đóng ROOT E) ---
# Lấy ở Supabase Dashboard → Settings → API → service_role key.
# ⚠️ KHÔNG bao giờ prefix NEXT_PUBLIC_. Key này bỏ qua RLS — lộ = full DB compromise.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# --- OpenAI (AI sinh câu hỏi / chat gia sư) ---
# Lấy ở https://platform.openai.com/api-keys. Chỉ dùng ở server, không expose client.
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx
# Model mặc định (khuyến nghị gpt-4o-mini cho chi phí thấp).
OPENAI_MODEL=gpt-4o-mini

# --- Anti-cheat HMAC (ký file save streak_data.json) ---
# BẮT BUỘC: không còn fallback mặc định. Sinh secret mạnh, vd:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Đổi giá trị này sẽ làm chữ ký các file save cũ mismatch → cần ký lại trước khi đổi.
SAT_PREP_SECRET=<chuỗi-ngẫu-nhiên-64-hex>

# --- Cổng thanh toán VNPay (Phase 2, SERVER-ONLY) ---
# Lấy ở merchant.vnpayment.vn (sandbox: sandbox.vnpayment.vn). KHÔNG prefix NEXT_PUBLIC_.
# Thiếu các biến này → /api/payment/create trả 503 (cổng chưa cấu hình), KHÔNG crash.
VNPAY_TMN_CODE=<tmn-code>
VNPAY_HASH_SECRET=<hash-secret>
VNPAY_HOST=https://sandbox.vnpayment.vn

# --- Cổng thanh toán MoMo (Phase 2, SERVER-ONLY) ---
# Lấy ở business.momo.vn / developers.momo.vn (sandbox: test-payment.momo.vn).
MOMO_PARTNER_CODE=<partner-code>
MOMO_ACCESS_KEY=<access-key>
MOMO_SECRET_KEY=<secret-key>
MOMO_CREATE_URL=https://test-payment.momo.vn/v2/gateway/api/create

# --- URL gốc của app (để dựng returnUrl/ipnUrl cho cổng thanh toán) ---
# Prod: https://sat-2026.vercel.app. Dev: http://localhost:3000. Nếu trống → dùng
# origin của request (đủ cho dev; nên set tường minh ở prod để cổng gọi IPN đúng).
APP_BASE_URL=https://sat-2026.vercel.app
