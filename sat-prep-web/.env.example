# ============================================================================
#  BIẾN MÔI TRƯỜNG CẦN SET (sao chép file này thành .env.local rồi điền giá trị)
#  KHÔNG commit .env.local — đã được .gitignore che (.env*).
# ============================================================================

# --- Supabase (Auth + Database) ---
# Lấy ở Supabase Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# --- Supabase Service Role (SERVER-ONLY, đóng ROOT E) ---
# Lấy ở Supabase Dashboard → Settings → API → service_role key.
# ⚠️ KHÔNG bao giờ prefix NEXT_PUBLIC_. Key này bỏ qua RLS — lộ = full DB compromise.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# --- OpenAI (AI sinh câu hỏi / chat gia sư) ---
# Lấy ở https://platform.openai.com/api-keys. Chỉ dùng ở server, không expose client.
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx
# Model mặc định (khuyến nghị gpt-4o-mini cho chi phí thấp).
OPENAI_MODEL=gpt-4o-mini
# (Tùy chọn) Base URL của OpenAI API. OpenAI CHẶN truy cập trực tiếp từ một số
# quốc gia (vd Việt Nam → lỗi 403 unsupported_country_region_territory). Nếu bị
# chặn, trỏ biến này tới một proxy/gateway TƯƠNG THÍCH OpenAI (cùng path
# /v1/chat/completions). KHÔNG đặt → gọi thẳng https://api.openai.com/v1.
# OPENAI_BASE_URL=https://your-proxy.example.com/v1

# --- Anti-cheat HMAC (ký file save streak_data.json) ---
# BẮT BUỘC: không còn fallback mặc định. Sinh secret mạnh, vd:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Đổi giá trị này sẽ làm chữ ký các file save cũ mismatch → cần ký lại trước khi đổi.
SAT_PREP_SECRET=<chuỗi-ngẫu-nhiên-64-hex>

# --- Cổng thanh toán Stripe (ĐANG DÙNG, SERVER-ONLY trừ PUBLISHABLE) ---
# Lấy ở https://dashboard.stripe.com/test/apikeys (bật Test Mode).
# Thiếu STRIPE_SECRET_KEY / STRIPE_WEBHOOK_SECRET → /api/payment/create trả 503
# (cổng chưa cấu hình), KHÔNG crash. Webhook cần cả 2 key để verify chữ ký.
# 🔴 VND là zero-decimal currency ở Stripe → unit_amount = số VND thật (KHÔNG ×100).
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx
# PUBLISHABLE: luồng Checkout hiện dùng redirect (server tạo session) nên client
# CHƯA cần key này — để sẵn cho tương lai (Stripe.js/Elements nhúng thẻ trực tiếp).
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxx

# --- Cổng thanh toán VNPay (⏸️ DISABLED — bật lại khi có creds doanh nghiệp) ---
# Code route/lib còn NGUYÊN; chỉ gỡ khỏi VALID_GATEWAYS (src/lib/payment.ts). Thêm
# 'vnpay' lại vào mảng đó + điền creds dưới đây để bật. Lấy ở merchant.vnpayment.vn.
VNPAY_TMN_CODE=<tmn-code>
VNPAY_HASH_SECRET=<hash-secret>
VNPAY_HOST=https://sandbox.vnpayment.vn

# --- Cổng thanh toán MoMo (⏸️ DISABLED — bật lại khi có creds doanh nghiệp) ---
# Tương tự VNPay: code còn nguyên, thêm 'momo' vào VALID_GATEWAYS để bật.
MOMO_PARTNER_CODE=<partner-code>
MOMO_ACCESS_KEY=<access-key>
MOMO_SECRET_KEY=<secret-key>
MOMO_CREATE_URL=https://test-payment.momo.vn/v2/gateway/api/create

# --- Admin Fulfillment (shared-secret, SERVER-ONLY) ---
# Bảo vệ /api/admin/redemptions (xử lý hàng đợi đổi quà pending→fulfilled/cancel).
# App chưa có role system → dùng 1 secret dùng-chung. Gửi qua header x-admin-secret.
# ⚠️ FAIL-CLOSED: KHÔNG set biến này → route trả 403 cho MỌI request (khoá cửa).
# Sinh secret mạnh: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADMIN_SECRET=<chuỗi-ngẫu-nhiên-mạnh>

# --- URL gốc của app (để dựng returnUrl/ipnUrl cho cổng thanh toán) ---
# Prod: https://sat-2026.vercel.app. Dev: http://localhost:3000. Nếu trống → dùng
# origin của request (đủ cho dev; nên set tường minh ở prod để cổng gọi IPN đúng).
APP_BASE_URL=https://sat-2026.vercel.app
